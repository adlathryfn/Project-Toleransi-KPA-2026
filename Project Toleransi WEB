<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KPA 2026 | Hizeb Usman - Project Toleransi</title>
    
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <!-- AOS Animation -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <style>
        /* ==================== CSS RESET & VARIABLES ==================== */
        :root {
            --hijau-tua: #0B4F3A;
            --hijau-muda: #0d6b4e;
            --emas: #C9A84C;
            --emas-muda: #d4b65e;
            --putih: #FFFFFF;
            --abu-muda: #F9F9F9;
            --abu-sedang: #E8E8E8;
            --teks-gelap: #1E1E1E;
            --teks-abu: #555555;
            --transisi: all 0.3s ease;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        html { scroll-behavior: smooth; scroll-padding-top: 80px; }

        body {
            font-family: 'Inter', 'Segoe UI', sans-serif;
            color: var(--teks-gelap);
            background-color: var(--putih);
            line-height: 1.7;
            overflow-x: hidden;
        }

        .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

        /* ==================== NAVBAR ==================== */
        .navbar {
            position: fixed; top: 0; left: 0; width: 100%; z-index: 1000;
            padding: 20px 0; transition: var(--transisi); background: transparent;
        }
        .navbar.scrolled {
            background: rgba(11, 79, 58, 0.95); backdrop-filter: blur(10px);
            padding: 12px 0; box-shadow: 0 4px 30px rgba(0,0,0,0.15);
        }
        .navbar .container { display: flex; justify-content: space-between; align-items: center; }
        .nav-logo {
            font-size: 1.4rem; font-weight: 800; color: var(--putih);
            text-decoration: none; display: flex; align-items: center; gap: 8px;
        }
        .nav-logo .logo-icon {
            width: 36px; height: 36px; background: var(--emas); border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.1rem; color: var(--hijau-tua); font-weight: 900;
        }
        .nav-menu { display: flex; list-style: none; gap: 4px; align-items: center; }
        .nav-menu li a {
            color: rgba(255,255,255,0.85); text-decoration: none; font-size: 0.9rem;
            font-weight: 500; padding: 8px 16px; border-radius: 50px; transition: var(--transisi);
        }
        .nav-menu li a:hover, .nav-menu li a.active { color: var(--putih); background: rgba(255,255,255,0.15); }
        .nav-menu li a.active { background: var(--emas); color: var(--hijau-tua); font-weight: 600; }
        .hamburger { display: none; flex-direction: column; cursor: pointer; gap: 5px; }
        .hamburger span { width: 28px; height: 3px; background: var(--putih); border-radius: 3px; transition: var(--transisi); }

        /* ==================== SECTION HEADER ==================== */
        .section-header { text-align: center; margin-bottom: 60px; }
        .section-label {
            display: inline-block; background: rgba(11,79,58,0.08); color: var(--hijau-tua);
            padding: 6px 16px; border-radius: 50px; font-size: 0.8rem; font-weight: 700;
            letter-spacing: 2px; text-transform: uppercase; margin-bottom: 16px;
        }
        .section-title { font-size: 2.5rem; font-weight: 800; margin-bottom: 16px; letter-spacing: -0.5px; }
        .section-subtitle { font-size: 1.1rem; color: var(--teks-abu); max-width: 650px; margin: 0 auto; }

        /* ==================== HERO ==================== */
        .hero {
            min-height: 100vh; display: flex; align-items: center; justify-content: center;
            position: relative; background: linear-gradient(135deg, #072e22 0%, #0B4F3A 30%, #0a3d2e 60%, #051f17 100%);
            overflow: hidden;
        }
        .hero-particles { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; }
        .particle {
            position: absolute; background: rgba(201,168,76,0.08); border-radius: 4px;
            animation: floatParticle 20s infinite ease-in-out;
        }
        .particle:nth-child(1) { width:60px; height:60px; top:10%; left:5%; }
        .particle:nth-child(2) { width:80px; height:80px; top:60%; left:80%; animation-delay:-5s; }
        .particle:nth-child(3) { width:40px; height:40px; top:30%; left:70%; animation-delay:-10s; }
        .particle:nth-child(4) { width:100px; height:100px; top:70%; left:15%; animation-delay:-15s; }
        .particle:nth-child(5) { width:50px; height:50px; top:50%; left:50%; animation-delay:-8s; }
        .particle:nth-child(6) { width:30px; height:70px; top:20%; left:40%; animation-delay:-12s; }
        .particle:nth-child(7) { width:70px; height:30px; top:80%; left:60%; animation-delay:-3s; }
        @keyframes floatParticle {
            0%,100% { transform:translateY(0) rotate(0deg); opacity:1; }
            25% { transform:translateY(-30px) rotate(5deg); opacity:0.6; }
            50% { transform:translateY(-15px) rotate(3deg); opacity:0.8; }
            75% { transform:translateY(-40px) rotate(-3deg); opacity:0.5; }
        }
        .hero-content { text-align: center; position: relative; z-index: 2; max-width: 800px; padding: 0 24px; }
        .trisula-container { margin-bottom: 30px; }
        .trisula-svg {
            width: 120px; filter: drop-shadow(0 0 40px rgba(201,168,76,0.5));
            animation: glowPulse 3s ease-in-out infinite;
        }
        @keyframes glowPulse {
            0%,100% { filter:drop-shadow(0 0 30px rgba(201,168,76,0.4)); }
            50% { filter:drop-shadow(0 0 60px rgba(201,168,76,0.8)); }
        }
        .hero-badge {
            display: inline-block; background: rgba(201,168,76,0.2);
            border: 1px solid rgba(201,168,76,0.4); color: var(--emas);
            padding: 8px 20px; border-radius: 50px; font-size: 0.85rem;
            font-weight: 600; letter-spacing: 1px; margin-bottom: 24px; text-transform: uppercase;
        }
        .hero h1 { font-size: 3.5rem; font-weight: 900; color: var(--putih); line-height: 1.2; margin-bottom: 20px; }
        .hero h1 .highlight {
            background: linear-gradient(135deg, var(--emas), #f0d78c, var(--emas));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .hero-subtitle { font-size: 1.2rem; color: rgba(255,255,255,0.8); margin-bottom: 40px; }
        .hero-subtitle strong { color: var(--emas); font-weight: 600; }
        .btn-primary {
            display: inline-flex; align-items: center; gap: 10px;
            background: var(--emas); color: var(--hijau-tua); padding: 16px 32px;
            border-radius: 50px; text-decoration: none; font-weight: 700; font-size: 1rem;
            transition: var(--transisi); cursor: pointer;
        }
        .btn-primary:hover { background: #d4b65e; transform: translateY(-2px); box-shadow: 0 10px 40px rgba(201,168,76,0.4); }
        .btn-primary:hover i { transform: translateY(4px); }
        .scroll-indicator {
            position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%);
            display: flex; flex-direction: column; align-items: center; gap: 8px; z-index: 2;
        }
        .scroll-indicator span { font-size: 0.75rem; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 2px; }
        .scroll-mouse { width: 26px; height: 42px; border: 2px solid rgba(255,255,255,0.4); border-radius: 14px; display: flex; justify-content: center; padding-top: 8px; }
        .scroll-dot { width: 5px; height: 5px; background: var(--emas); border-radius: 50%; animation: scrollAnim 1.5s ease-in-out infinite; }
        @keyframes scrollAnim { 0%,100% { transform:translateY(0); opacity:1; } 50% { transform:translateY(12px); opacity:0.3; } }

        /* ==================== TENTANG KPA ==================== */
        .tentang-section { padding: 100px 0; background: var(--putih); }
        .pilar-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; margin-top: 50px; }
        .pilar-card {
            background: var(--putih); border: 1px solid var(--abu-sedang); border-radius: 20px;
            padding: 36px 28px; transition: all 0.4s cubic-bezier(0.25,0.8,0.25,1.2);
            position: relative; overflow: hidden;
        }
        .pilar-card::before {
            content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 4px;
            background: linear-gradient(90deg, var(--hijau-tua), var(--emas));
            transform: scaleX(0); transform-origin: left; transition: transform 0.4s ease;
        }
        .pilar-card:hover::before { transform: scaleX(1); }
        .pilar-card:hover { transform: translateY(-8px); box-shadow: 0 20px 60px rgba(0,0,0,0.08); border-color: transparent; }
        .pilar-icon {
            width: 60px; height: 60px; border-radius: 16px; display: flex; align-items: center;
            justify-content: center; font-size: 1.6rem; margin-bottom: 20px;
        }
        .pilar-icon.gold { background: linear-gradient(135deg, rgba(201,168,76,0.2), rgba(201,168,76,0.1)); color: var(--emas); }
        .pilar-icon.green { background: linear-gradient(135deg, rgba(11,79,58,0.15), rgba(11,79,58,0.05)); color: var(--hijau-tua); }
        .pilar-card h3 { font-size: 1.3rem; font-weight: 700; margin-bottom: 8px; }
        .pilar-card .pilar-tag { font-size: 0.75rem; font-weight: 700; color: var(--emas); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 16px; display: block; }
        .pilar-card p { font-size: 0.95rem; color: var(--teks-abu); }
        .pilar-card ul { list-style: none; margin-top: 12px; }
        .pilar-card ul li { font-size: 0.9rem; color: var(--teks-abu); padding: 4px 0 4px 20px; position: relative; }
        .pilar-card ul li::before { content: '→'; position: absolute; left: 0; color: var(--emas); font-weight: 600; }
        .pilar-card.featured { border-color: rgba(201,168,76,0.3); background: linear-gradient(180deg, rgba(201,168,76,0.04) 0%, #fff 100%); }

        /* ==================== PROYEK ==================== */
        .proyek-section { padding: 100px 0; background: var(--abu-muda); }
        .proyek-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
        .proyek-image .img-placeholder {
            width: 100%; aspect-ratio: 4/3; background: linear-gradient(135deg, var(--hijau-tua), #0a3d2e);
            border-radius: 20px; display: flex; align-items: center; justify-content: center;
            color: rgba(255,255,255,0.3); font-size: 4rem;
        }
        .proyek-content h2 { font-size: 2rem; font-weight: 800; margin-bottom: 16px; }
        .badge-reward {
            display: inline-flex; align-items: center; gap: 8px;
            background: linear-gradient(135deg, var(--emas), #b8942f); color: var(--putih);
            padding: 10px 20px; border-radius: 50px; font-size: 0.85rem; font-weight: 700;
            margin-bottom: 24px; box-shadow: 0 4px 20px rgba(201,168,76,0.3);
        }
        .proyek-content h3 { font-size: 1.1rem; font-weight: 700; color: var(--hijau-tua); margin: 20px 0 8px; }
        .proyek-content p { font-size: 1rem; color: var(--teks-abu); line-height: 1.8; }

        /* ==================== METODOLOGI ==================== */
        .metodologi-section { padding: 100px 0; background: var(--putih); }
        .metodologi-steps { display: flex; gap: 0; position: relative; margin-top: 50px; }
        .metodologi-steps::before {
            content: ''; position: absolute; top: 40px; left: 15%; right: 15%; height: 3px;
            background: linear-gradient(90deg, var(--emas), var(--hijau-tua), var(--emas)); border-radius: 2px; z-index: 0;
        }
        .step-card { flex: 1; text-align: center; position: relative; z-index: 1; padding: 0 16px; }
        .step-number {
            width: 80px; height: 80px; border-radius: 50%; background: var(--putih);
            border: 4px solid var(--hijau-tua); display: flex; align-items: center; justify-content: center;
            margin: 0 auto 24px; font-size: 2rem; font-weight: 900; color: var(--hijau-tua);
            transition: all 0.4s cubic-bezier(0.25,0.8,0.25,1.2);
        }
        .step-card:hover .step-number { background: var(--hijau-tua); color: var(--putih); transform: scale(1.1); box-shadow: 0 10px 40px rgba(11,79,58,0.3); }
        .step-card h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 8px; }
        .step-card p { font-size: 0.9rem; color: var(--teks-abu); }
        .step-tools { display: inline-flex; flex-wrap: wrap; gap: 6px; justify-content: center; margin-top: 12px; }
        .step-tool { background: rgba(11,79,58,0.08); color: var(--hijau-tua); padding: 4px 12px; border-radius: 50px; font-size: 0.75rem; font-weight: 600; }

        /* ==================== HASIL ==================== */
        .hasil-section { padding: 100px 0; background: var(--abu-muda); }
        .hasil-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; margin-top: 50px; }
        .hasil-card { background: var(--putih); border-radius: 20px; padding: 36px; box-shadow: 0 4px 20px rgba(0,0,0,0.04); }
        .hasil-card h3 { font-size: 1.2rem; font-weight: 700; display: flex; align-items: center; gap: 10px; }
        .card-badge { display: inline-block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; padding: 4px 12px; border-radius: 50px; margin-bottom: 20px; }
        .card-badge.kuantitatif { background: rgba(11,79,58,0.1); color: var(--hijau-tua); }
        .card-badge.kualitatif { background: rgba(201,168,76,0.15); color: #8b6914; }
        .chart-container { position: relative; width: 100%; max-width: 400px; margin: 20px auto; height: 280px; }
        .chart-container canvas { width: 100% !important; height: 100% !important; }
        .hasil-narasi { font-size: 0.95rem; color: var(--teks-abu); margin-top: 16px; padding: 16px; background: var(--abu-muda); border-radius: 12px; border-left: 4px solid var(--emas); }
        .quote-carousel { position: relative; overflow: hidden; min-height: 200px; margin-top: 16px; }
        .quote-slide { position: absolute; top: 0; left: 0; width: 100%; opacity: 0; transition: opacity 0.8s ease; }
        .quote-slide.active { opacity: 1; position: relative; }
        .quote-card { background: var(--abu-muda); border-radius: 16px; padding: 24px; }
        .quote-card .quote-icon { font-size: 2.5rem; color: var(--emas); opacity: 0.3; margin-bottom: 8px; }
        .quote-card p { font-size: 1rem; font-style: italic; margin-bottom: 12px; }
        .quote-card .quote-author { font-size: 0.85rem; font-weight: 700; color: var(--hijau-tua); }
        .quote-card .quote-role { font-size: 0.8rem; color: var(--teks-abu); }
        .quote-dots { display: flex; gap: 8px; justify-content: center; margin-top: 16px; }
        .quote-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--abu-sedang); cursor: pointer; transition: all 0.3s; }
        .quote-dot.active { background: var(--emas); transform: scale(1.3); }
        .btn-outline { display: inline-flex; align-items: center; gap: 8px; background: transparent; color: var(--hijau-tua); border: 2px solid var(--hijau-tua); padding: 12px 24px; border-radius: 50px; text-decoration: none; font-weight: 600; transition: var(--transisi); }
        .btn-outline:hover { background: var(--hijau-tua); color: var(--putih); }
        .btn-center { text-align: center; margin-top: 40px; }

        /* ==================== CAPAIAN ==================== */
        .capaian-section { padding: 100px 0; background: var(--putih); }
        .capaian-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-top: 50px; }
        .capaian-card { text-align: center; padding: 32px 20px; border-radius: 20px; border: 1px solid var(--abu-sedang); transition: all 0.3s; }
        .capaian-card:hover { transform: translateY(-6px); box-shadow: 0 16px 48px rgba(0,0,0,0.06); border-color: var(--emas); }
        .capaian-icon { width: 56px; height: 56px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; font-size: 1.3rem; }
        .capaian-icon.engagement { background: rgba(11,79,58,0.1); color: var(--hijau-tua); }
        .capaian-icon.kaderisasi { background: rgba(201,168,76,0.15); color: #8b6914; }
        .capaian-icon.internalisasi { background: rgba(11,79,58,0.08); color: var(--hijau-tua); }
        .capaian-icon.sustainability { background: rgba(201,168,76,0.1); color: #8b6914; }
        .capaian-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 4px; }
        .capaian-card .capaian-en { font-size: 0.75rem; color: var(--emas); font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; margin-bottom: 12px; display: block; }
        .capaian-card p { font-size: 0.85rem; color: var(--teks-abu); }

        /* ==================== TIM ==================== */
        .tim-section { padding: 100px 0; background: var(--putih); }
        .mentor-badge { display: flex; justify-content: center; gap: 16px; margin-bottom: 40px; flex-wrap: wrap; }
        .mentor-tag { background: linear-gradient(135deg, rgba(201,168,76,0.15), rgba(201,168,76,0.05)); border: 1px solid rgba(201,168,76,0.3); color: #8b6914; padding: 10px 20px; border-radius: 50px; font-size: 0.9rem; font-weight: 600; display: flex; align-items: center; gap: 8px; }
        .tim-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
        .tim-card { background: var(--putih); border: 1px solid var(--abu-sedang); border-radius: 20px; padding: 32px 24px; text-align: center; transition: all 0.4s cubic-bezier(0.25,0.8,0.25,1.2); position: relative; overflow: hidden; }
        .tim-card::after { content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 0; height: 3px; background: var(--emas); border-radius: 2px; transition: width 0.4s ease; }
        .tim-card:hover::after { width: 60%; }
        .tim-card:hover { transform: translateY(-8px); box-shadow: 0 20px 60px rgba(0,0,0,0.08); border-color: rgba(201,168,76,0.3); }
        .tim-card.featured-member { border-color: rgba(201,168,76,0.4); background: linear-gradient(180deg, rgba(201,168,76,0.06) 0%, #fff 100%); }
        .tim-avatar { width: 72px; height: 72px; border-radius: 50%; background: linear-gradient(135deg, var(--hijau-tua), #0d6b4e); color: var(--putih); display: flex; align-items: center; justify-content: center; font-size: 1.8rem; font-weight: 700; margin: 0 auto 16px; position: relative; }
        .tim-card.featured-member .tim-avatar { background: linear-gradient(135deg, var(--emas), #b8942f); box-shadow: 0 8px 32px rgba(201,168,76,0.3); }
        .tim-avatar .status-dot { position: absolute; bottom: 4px; right: 4px; width: 14px; height: 14px; background: #22c55e; border: 3px solid var(--putih); border-radius: 50%; }
        .tim-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 4px; }
        .tim-role { font-size: 0.8rem; color: var(--emas); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; display: block; }
        .tim-divisi { display: inline-block; background: rgba(11,79,58,0.08); color: var(--hijau-tua); padding: 4px 12px; border-radius: 50px; font-size: 0.75rem; font-weight: 600; }
        .tim-status { font-size: 0.75rem; color: #22c55e; font-weight: 600; margin-top: 8px; display: flex; align-items: center; justify-content: center; gap: 4px; }

        /* ==================== TIMELINE ==================== */
        .timeline-section { padding: 100px 0; background: var(--hijau-tua); color: var(--putih); }
        .timeline-section .section-label { background: rgba(255,255,255,0.1); color: var(--emas); }
        .timeline-section .section-title { color: var(--putih); }
        .timeline-section .section-subtitle { color: rgba(255,255,255,0.7); }
        .timeline { position: relative; max-width: 700px; margin: 50px auto 0; padding-left: 40px; }
        .timeline::before { content: ''; position: absolute; left: 18px; top: 0; bottom: 0; width: 3px; background: linear-gradient(180deg, var(--emas), rgba(201,168,76,0.3), var(--emas)); border-radius: 2px; }
        .timeline-item { position: relative; margin-bottom: 40px; padding-left: 30px; }
        .timeline-item:last-child { margin-bottom: 0; }
        .timeline-item::before { content: ''; position: absolute; left: -26px; top: 6px; width: 16px; height: 16px; background: var(--emas); border: 3px solid var(--hijau-tua); border-radius: 50%; z-index: 2; box-shadow: 0 0 0 4px rgba(201,168,76,0.2); }
        .timeline-item.highlight::before { background: var(--putih); border-color: var(--emas); animation: pulseTimeline 2s infinite; }
        @keyframes pulseTimeline { 0%,100% { box-shadow: 0 0 0 4px rgba(201,168,76,0.3); } 50% { box-shadow: 0 0 0 12px rgba(201,168,76,0.1); } }
        .timeline-date { font-size: 0.85rem; font-weight: 700; color: var(--emas); margin-bottom: 6px; }
        .timeline-item h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 6px; }
        .timeline-item p { font-size: 0.9rem; color: rgba(255,255,255,0.7); }
        .timeline-detail { margin-top: 10px; padding: 14px 18px; background: rgba(255,255,255,0.06); border-radius: 12px; border-left: 3px solid var(--emas); }
        .timeline-detail ul { list-style: none; }
        .timeline-detail ul li { font-size: 0.85rem; color: rgba(255,255,255,0.75); padding: 3px 0 3px 16px; position: relative; }
        .timeline-detail ul li::before { content: '•'; position: absolute; left: 0; color: var(--emas); }

        /* ==================== ANGGARAN ==================== */
        .anggaran-section { padding: 100px 0; background: var(--abu-muda); }
        .anggaran-grid { display: grid; grid-template-columns: 1fr 1.5fr; gap: 40px; margin-top: 50px; }
        .anggaran-total { background: linear-gradient(135deg, var(--hijau-tua), #0a3d2e); border-radius: 20px; padding: 40px 32px; text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center; color: var(--putih); }
        .anggaran-total .label { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 2px; color: rgba(255,255,255,0.6); margin-bottom: 12px; }
        .anggaran-total .nominal { font-size: 3rem; font-weight: 900; color: var(--emas); }
        .anggaran-total .keterangan { font-size: 0.85rem; color: rgba(255,255,255,0.6); margin-top: 8px; }
